{
  "compilerOptions": {
    "composite": true,
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "importHelpers": true,
    "isolatedModules": true,
    "lib": ["es2022"],
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "noEmitOnError": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "es2022",
    "customConditions": ["@org/source"],
    "paths": {
      "@aalizo/shared-ui": ["libs/shared/ui/src/index.ts"],
      "@aalizo/utils": ["libs/shared/utils/src/index.ts"],
      "@aalizo/database": ["libs/shared/database/src/index.ts"],
      "@aalizo/types": ["libs/shared/types/src/index.ts"]
    }
  }
}
